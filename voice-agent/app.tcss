/* ── App-wide ─────────────────────────────────────────── */

Screen {
    background: $surface;
}

#conversation {
    padding: 1 2 0 2;
    background: $surface;
}

/* ── Turn cards ───────────────────────────────────────── */

UserTurn, AgentTurn, ToolCard, ErrorCard {
    width: 100%;
    height: auto;
    margin: 0 0 1 0;
    padding: 0 1;
}

.card-header {
    height: 1;
    width: 100%;
}

.card-header > .label {
    width: 1fr;
}

CopyButton {
    width: auto;
    height: 1;
    padding: 0 1;
    color: $text-muted;
    text-style: dim;
}

CopyButton:hover {
    color: $accent;
    text-style: bold;
    background: $boost;
}

UserTurn {
    border: round $primary-lighten-1;
}

UserTurn .label {
    color: $primary-lighten-3;
    text-style: bold;
}

UserTurn > .stt {
    color: $text-muted;
    text-style: dim;
    margin-top: 1;
}

AgentTurn {
    border: round $accent;
}

AgentTurn .label {
    color: $accent-lighten-2;
    text-style: bold;
}

AgentTurn > #body {
    height: auto;
    padding: 0 0;
    color: $text;
}

AgentTurn > .metrics {
    color: $text-muted;
    text-style: dim;
    margin-top: 1;
}

AgentTurn.-interrupted > #body {
    color: $text-muted;
}

ToolCard {
    border: round $warning;
    color: $text-muted;
}

ToolCard > .label {
    color: $warning;
    text-style: bold;
}

ErrorCard {
    border: round $error;
}

ErrorCard > .label {
    color: $error;
    text-style: bold;
}

ApprovalCard {
    border: round $warning;
    padding: 0 1;
    margin: 0 0 1 0;
    height: auto;
    width: 100%;
}

ApprovalCard > .label {
    color: $warning;
    text-style: bold;
}

ApprovalCard > .body {
    color: $text;
    padding: 0 0 1 0;
}

ApprovalCard > .decision {
    color: $text-muted;
    text-style: dim;
}

ApprovalCard .approval-buttons {
    height: 3;
    width: 100%;
    align-horizontal: left;
}

ApprovalCard .approval-buttons > Button {
    margin: 0 1 0 0;
    min-width: 14;
}

/* ── Status footer ────────────────────────────────────── */

StatusFooter {
    dock: bottom;
    height: auto;
    width: 100%;
    background: $panel;
    border-top: solid $primary-darken-2;
}

StateRow {
    height: auto;
    width: 100%;
    padding: 0 2;
    color: $text;
}

ModelRow {
    height: auto;
    width: 100%;
    padding: 0 2;
    color: $text-muted;
    text-style: dim;
}

ToolsRow {
    height: auto;
    width: 100%;
    padding: 0 2;
    color: $text-muted;
    text-style: dim;
}

ControlRow {
    height: 3;
    width: 100%;
    padding: 0 1;
    margin-top: 1;
    align-horizontal: center;
}

ControlRow > Button {
    width: 1fr;             /* share available space equally */
    min-width: 1;           /* allow shrinking below natural content width */
    max-width: 28;          /* cap so wide terminals don't inflate them */
    margin: 0 1;
}

ControlRow > Button.-hidden {
    display: none;
}

/* ── Splash screen ────────────────────────────────────── */

SplashScreen {
    align: center middle;
    background: $surface;
}

#splash-panel {
    width: 70;
    height: auto;
    max-height: 80%;
    border: round $accent;
    padding: 1 2;
    background: $panel;
}

#splash-title {
    width: 100%;
    content-align: center middle;
    color: $accent;
    text-style: bold;
    padding: 0 0 1 0;
}

#splash-servers {
    height: auto;
    padding: 0 0 1 0;
}

#splash-servers > ServerRow {
    height: 1;
    width: 100%;
}

#splash-log {
    height: auto;
    max-height: 10;
    color: $text-muted;
    text-style: dim;
}

#splash-log > Static {
    height: 1;
    width: 100%;
}

/* ── Settings modal ───────────────────────────────────── */

SettingsScreen {
    align: center middle;
    background: $surface 60%;
}

#settings-panel {
    width: 80%;             /* scale with the terminal */
    max-width: 80;          /* but cap so it doesn't look stretched */
    min-width: 36;
    height: auto;
    max-height: 90%;
    border: round $accent;
    padding: 1 2;
    background: $panel;
}

#settings-title {
    width: 100%;
    content-align: center middle;
    color: $accent;
    text-style: bold;
}

#settings-rows {
    height: auto;
}

.settings-label {
    width: 100%;
    color: $text-muted;
    text-style: dim;
    margin-top: 1;          /* vertical gap between each role block */
}

#settings-rows > Select {
    width: 100%;
}

#settings-buttons {
    height: auto;
    width: 100%;
    align-horizontal: center;
    margin-top: 2;          /* clear visual gap above the action buttons */
}

#settings-buttons > Button {
    width: 1fr;             /* share available width equally */
    min-width: 1;           /* allow shrinking on narrow terminals */
    max-width: 20;          /* cap on wide terminals */
    margin: 0 1;
}
